    "witness1_signature": {
      "type": "string",
      "description": "\u0e25\u0e32\u0e22\u0e40\u0e0b\u0e47\u0e19\u0e1e\u0e22\u0e32\u0e19\u0e04\u0e19\u0e17\u0e35\u0e48 1 (Base64)"
