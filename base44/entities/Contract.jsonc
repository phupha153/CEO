    "witness2_name": {
      "type": "string",
      "description": "\u0e0a\u0e37\u0e48\u0e2d\u0e1e\u0e22\u0e32\u0e19\u0e04\u0e19\u0e17\u0e35\u0e48 2"
    },
    "witness2_signature": {
      "type": "string",
      "description": "\u0e25\u0e32\u0e22\u0e40\u0e0b\u0e47\u0e19\u0e1e\u0e22\u0e32\u0e19\u0e04\u0e19\u0e17\u0e35\u0e48 2 (Base64)"
    },
    "remarks": {
      "type": "string",
      "description": "\u0e2b\u0e21\u0e32\u0e22\u0e40\u0e2b\u0e15\u0e38\u0e40\u0e1e\u0e34\u0e48\u0e21\u0e40\u0e15\u0e34\u0e21"
